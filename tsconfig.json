{
  "compilerOptions": {
    "target": "es2020",
    "lib": [
      "dom",
      "dom.iterable",
      "es2020"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "node",
      "react",
      "react-dom"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src",
    "api-backup",
    "siteground-deploy",
    "_disabled_routes",
    "_git_backup_2025-12-13",
    "_git_backup*",
    "supabase/functions",
    "app/supabase/functions",
    "temp-backup-api.disabled",

    // Pre-App-Router root-level route trees: duplicated under app/, NOT routed by
    // Next, NOT imported by the real app (verified). Excluded so tsc reflects the
    // live app. Dead code; safe to delete later.
    "company",
    "driver",
    "driver-resume",
    "recruit",
    "fastscan",
    "performance-test",
    "recruiter-profile",
    "driver_upload_document",
    "mobile",
    "veronica",
    "sales-dashboard",
    "hiring",
    "fleet-dashboard",
    "driver-dashboard",
    "company-dashboard"
  ]
}
