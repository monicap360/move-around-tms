{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["dom", "dom.iterable", "es2020"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "react", "react-dom"],
    "paths": {
      "@/*": ["./*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "driver",
    "fleet",
    "company",
    "apply",
    "veronica",
    "assets",
    "api-backup",
    "siteground-deploy",
    "_disabled_routes",
    "_git_backup_2025-12-13",
    "_git_backup*",
    "supabase/functions",
    "temp-backup-api.disabled",
    "src",
    "recruit",
    "recruiter",
    "ronyx",
    "sales-dashboard",
    "app/supabase/functions",
    "app/recruit",
    "app/recruiter",
    "app/sales-dashboard",
    "components",
    "company-dashboard",
    "dispatch",
    "driver-dashboard",
    "driver_upload_document",
    "fastscan",
    "fleet-dashboard",
    "hiring",
    "mobile",
    "partners",
    "performance-test",
    "reconciliation"
  ]
}
